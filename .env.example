# ===================================
# Vaultify Environment Variables
# Copy to .env and fill in values
# ===================================

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/vaultify

# Security — JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars

# Security — Encryption (32-byte hex string for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Service Split — Ports
PROXY_PORT=3001
ADMIN_PORT=3002
AUDIT_PORT=3003
ADMIN_SERVICE_URL=http://localhost:3002
AUDIT_SERVICE_URL=http://localhost:3003

# Internal API key used by proxy-service → admin-service communication
INTERNAL_API_KEY=generate-a-random-64-char-string-here

# TLS / mTLS (optional — uncomment for mTLS between services)
# PROXY_TLS_CERT=./certs/proxy-service.crt
# PROXY_TLS_KEY=./certs/proxy-service.key
# ADMIN_TLS_CERT=./certs/admin-service.crt
# ADMIN_TLS_KEY=./certs/admin-service.key
# TLS_CA=./certs/ca.crt

# Vercel Integration (optional — needed for CLI push)
VERCEL_API_TOKEN=your-vercel-api-token

# Notifications (optional)
RESEND_API_KEY=re_xxxx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Frontend
VITE_API_BASE_URL=http://localhost:3001
